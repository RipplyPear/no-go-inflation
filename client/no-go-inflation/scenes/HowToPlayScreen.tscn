[node name="RichTextLabel" type="RichTextLabel" parent="CenterContainer/PanelContainer/MarginContainer/VBoxContainer" unique_id=172726285]
layout_mode = 2
text = "1. Host-ul creează un lobby și trimite codul celuilalt jucător.
2. Fiecare jucător primește o hartă proprie.
3. Construiește clădiri pe tile-uri potrivite.
4. Clădirile produc resurse în timp.
5. Colectează resursele și folosește-le pentru upgrade-uri sau tranzacții.
6. Creează sau acceptă oferte în piață.
7. Menține inflația sub control până la finalul sesiunii."
fit_content = true
horizontal_alignment = 1

